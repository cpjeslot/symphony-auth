{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}System Administration Dashboard{% endblock %}

{% block main %}
    <div class="row g-4 mb-4">
        {# Metric Cards #}
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">Total Users</div>
                        <h2 class="fw-bold mb-0">{{ total_users }}</h2>
                    </div>
                    <i class="fa fa-users fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController') }}" class="text-white text-decoration-none">
                        View All <i class="fa fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">Security Alerts (24h)</div>
                        <h2 class="fw-bold mb-0">{{ recent_alerts }}</h2>
                    </div>
                    <i class="fa fa-triangle-exclamation fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\SecurityAuditLogCrudController') }}" class="text-white text-decoration-none">
                        Investigate <i class="fa fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">Active Sessions</div>
                        <h2 class="fw-bold mb-0">{{ active_sessions }}</h2>
                    </div>
                    <i class="fa fa-bolt fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\ActiveSessionCrudController') }}" class="text-white text-decoration-none">
                        Manage Sessions <i class="fa fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-info text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">Social Accounts</div>
                        <h2 class="fw-bold mb-0">{{ total_social_accounts }}</h2>
                    </div>
                    <i class="fa fa-share-nodes fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\SocialAccountCrudController') }}" class="text-white text-decoration-none">
                        View Connections <i class="fa fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Recent Security Events</h5>
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\SecurityAuditLogCrudController') }}" class="btn btn-sm btn-link text-decoration-none">View All</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Event</th>
                                <th>User</th>
                                <th>IP Address</th>
                                <th>Time</th>
                                <th>Severity</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for event in recent_events %}
                                <tr>
                                    <td>
                                        <div class="fw-bold">{{ event.eventType.value }}</div>
                                        <div class="small text-muted">{{ event.description|slice(0, 50) }}...</div>
                                    </td>
                                    <td>{{ event.user ? event.user.email : 'System' }}</td>
                                    <td><code>{{ event.ipAddress }}</code></td>
                                    <td>{{ event.createdAt|date('H:i:s') }}</td>
                                    <td>
                                        <span class="badge bg-{{ event.severity == 'error' ? 'danger' : (event.severity == 'warning' ? 'warning' : 'info') }}">
                                            {{ event.severity|upper }}
                                        </span>
                                    </td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="5" class="text-center py-4 text-muted">No recent events found</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-3">Quick Actions</h5>
                <div class="d-grid gap-2">
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\UserCrudController').setAction('new') }}" class="btn btn-primary py-2">
                        <i class="fa fa-user-plus me-2"></i> Create New User
                    </a>
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\SecurityAuditLogCrudController') }}" class="btn btn-outline-danger py-2">
                        <i class="fa fa-shield-halved me-2"></i> System Audit
                    </a>
                    <a href="{{ ea_url().setController('App\\Controller\\Admin\\EmailOtpCrudController') }}" class="btn btn-outline-secondary py-2">
                        <i class="fa fa-key me-2"></i> Monitor OTPs
                    </a>
                </div>
                <hr class="my-4">
                <h5 class="fw-bold mb-3">System Health</h5>
                <div class="small">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Auth Service</span>
                        <span class="text-success"><i class="fa fa-circle-check me-1"></i> Operational</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Database</span>
                        <span class="text-success"><i class="fa fa-circle-check me-1"></i> Connected</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Mailer</span>
                        <span class="text-success"><i class="fa fa-circle-check me-1"></i> Active</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Redis Cache</span>
                        <span class="text-warning"><i class="fa fa-circle-exclamation me-1"></i> Pending</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
