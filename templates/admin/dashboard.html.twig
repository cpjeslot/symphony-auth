{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Admin Dashboard{% endblock %}

{% block main %}
    <div class="row g-4 mb-4">
        {# Metric Cards #}
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">Total Users</div>
                        <h2 class="fw-bold mb-0">{{ total_users }}</h2>
                    </div>
                    <i class="fa fa-users fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <a href="{{ ea_url().setController('App\\Admin\\UserCrudController') }}" class="text-white text-decoration-none">
                        View Users <i class="fa fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-danger text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">Security Alerts (24h)</div>
                        <h2 class="fw-bold mb-0">{{ recent_alerts }}</h2>
                    </div>
                    <i class="fa fa-shield-halved fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <a href="{{ ea_url().setController('App\\Admin\\SecurityAuditLogCrudController') }}" class="text-white text-decoration-none">
                        View Alerts <i class="fa fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">Active Sessions</div>
                        <h2 class="fw-bold mb-0">--</h2>
                    </div>
                    <i class="fa fa-clock fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <span class="opacity-75">Real-time tracking enabled</span>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-info text-white p-3">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="small opacity-75">System Status</div>
                        <h2 class="fw-bold mb-0">Secure</h2>
                    </div>
                    <i class="fa fa-circle-check fs-1 opacity-25"></i>
                </div>
                <div class="mt-3 small">
                    <span class="opacity-75">All protocols active</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm p-4">
                <h5 class="fw-bold mb-4">Quick Links</h5>
                <div class="row g-3">
                    <div class="col-6">
                        <a href="{{ ea_url().setController('App\\Admin\\UserCrudController').setAction('new') }}" class="btn btn-outline-primary w-100 py-3 d-flex flex-column align-items-center">
                            <i class="fa fa-user-plus mb-2 fs-4"></i>
                            <span>Add New User</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="{{ ea_url().setController('App\\Admin\\SecurityAuditLogCrudController') }}" class="btn btn-outline-danger w-100 py-3 d-flex flex-column align-items-center">
                            <i class="fa fa-shield mb-2 fs-4"></i>
                            <span>Audit Trail</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="{{ path('app_profile') }}" class="btn btn-outline-secondary w-100 py-3 d-flex flex-column align-items-center">
                            <i class="fa fa-user mb-2 fs-4"></i>
                            <span>My Profile</span>
                        </a>
                    </div>
                    <div class="col-6">
                        <a href="{{ path('app_logout') }}" class="btn btn-outline-dark w-100 py-3 d-flex flex-column align-items-center">
                            <i class="fa fa-sign-out mb-2 fs-4"></i>
                            <span>Sign Out</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm p-4 h-100">
                <h5 class="fw-bold mb-3">Security Overview</h5>
                <p class="text-muted small">The system is currently operating under production security protocols.</p>
                <hr>
                <div class="small mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span>Password Hashing</span>
                        <span class="badge bg-success">Argon2id</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>API Auth</span>
                        <span class="badge bg-success">JWT Stateless</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span>2FA Protocol</span>
                        <span class="badge bg-success">Email OTP</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span>Rate Limiting</span>
                        <span class="badge bg-success">Active</span>
                    </div>
                </div>
                <div class="mt-auto">
                    <div class="alert alert-info py-2 px-3 small mb-0">
                        <i class="fa fa-info-circle me-2"></i>
                        Next system audit in 12 days.
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
