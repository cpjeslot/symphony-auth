{% extends 'base.html.twig' %}

{% block title %}Admin Login{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card animate-fade-in">
        <div class="auth-brand">
            <div class="brand-icon">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h1>Admin Panel</h1>
            <p>Please authenticate to access system controls</p>
        </div>

        <div class="glass-card p-4 shadow-lg">
            <form method="post" action="{{ path('security_admin_login') }}">
                {% if error %}
                    <div class="alert alert-danger mb-4">
                        <i class="bi bi-exclamation-triangle me-2"></i>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                <div class="mb-3">
                    <label for="email" class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input type="email" value="{{ last_username }}" name="_username" id="email" class="form-control" autocomplete="email" required autofocus placeholder="admin@example.com">
                    </div>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-key"></i></span>
                        <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required placeholder="••••••••">
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('password', 'toggle-btn')" id="toggle-btn">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <div class="mb-3 form-check">
                    <input type="checkbox" name="_remember_me" id="remember_me" class="form-check-input">
                    <label class="form-check-label small text-muted" for="remember_me">Remember my session</label>
                </div>

                <button class="btn btn-primary w-100 mb-3" type="submit">
                    <i class="bi bi-unlock-fill me-2"></i> Access Dashboard
                </button>
                
                <div class="text-center">
                    <a href="{{ path('app_landing') }}" class="text-decoration-none small text-muted">
                        <i class="bi bi-arrow-left me-1"></i> Back to Landing Page
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
