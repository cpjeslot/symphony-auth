{% extends 'base.html.twig' %}

{% block title %}Sign In{% endblock %}
{% block meta_description %}Sign in to your account securely{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card animate-fade-in">
        
        {# Brand #}
        <div class="auth-brand">
            <div class="brand-icon">🔐</div>
            <h1>Welcome back</h1>
            <p>Sign in with your email or mobile number</p>
        </div>
        
        <div class="glass-card p-4">
            
            {# Auth Error #}
            {% if error %}
                <div class="alert alert-danger mb-3">
                    <i class="bi bi-exclamation-circle me-2"></i>
                    {{ error.messageKey|trans(error.messageData, 'security') }}
                </div>
            {% endif %}
            
            {# Login Form #}
            <form method="post" action="{{ path('app_login') }}" id="login-form" novalidate>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                
                <div class="mb-3">
                    <label class="form-label" for="login-identifier">Email or Mobile Number</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" 
                               id="login-identifier"
                               name="_identifier" 
                               class="form-control"
                               value="{{ last_username }}"
                               placeholder="you@example.com or +14155552671"
                               autocomplete="username"
                               autofocus
                               required>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label class="form-label mb-0" for="login-password">Password</label>
                        <a href="{{ path('app_forgot_password') }}" class="text-primary small">Forgot password?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" 
                               id="login-password"
                               name="_password" 
                               class="form-control"
                               placeholder="Your password"
                               autocomplete="current-password"
                               required>
                        <button class="btn btn-outline-secondary" type="button" id="toggleLoginPwd"
                                onclick="togglePassword('login-password', 'toggleLoginPwd')">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>
                
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="remember-me" name="_remember_me">
                        <label class="form-check-label small" for="remember-me">Remember me for 30 days</label>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
                </button>
            </form>
            
            {# Social Login Divider #}
            <div class="auth-divider mt-4">
                <span>or continue with</span>
            </div>
            
            <div class="row g-2">
                <div class="col-6">
                    <a href="{{ path('oauth_connect', {'provider': 'google'}) }}" class="btn-outline-social">
                        <svg width="16" height="16" viewBox="0 0 24 24">
                            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                        </svg>
                        Google
                    </a>
                </div>
                <div class="col-6">
                    <a href="{{ path('oauth_connect', {'provider': 'github'}) }}" class="btn-outline-social">
                        <i class="bi bi-github" style="font-size: 1rem;"></i> GitHub
                    </a>
                </div>
                <div class="col-6">
                    <a href="{{ path('oauth_connect', {'provider': 'facebook'}) }}" class="btn-outline-social">
                        <i class="bi bi-facebook" style="color: #1877F2; font-size: 1rem;"></i> Facebook
                    </a>
                </div>
                <div class="col-6">
                    <a href="{{ path('oauth_connect', {'provider': 'apple'}) }}" class="btn-outline-social">
                        <i class="bi bi-apple" style="font-size: 1rem;"></i> Apple
                    </a>
                </div>
            </div>
            
            <p class="text-center text-muted small mt-4 mb-0">
                Don't have an account? 
                <a href="{{ path('app_register') }}" class="text-primary fw-medium">Create one</a>
            </p>
        </div>
        
        {# Security note #}
        <p class="text-center text-muted mt-3" style="font-size: 0.75rem;">
            <i class="bi bi-shield-check me-1"></i>
            Protected by enterprise-grade security
        </p>
    </div>
</div>
{% endblock %}
