{% extends 'base.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card animate-fade-in" style="max-width: 440px;">
        
        <div class="auth-brand">
            <div class="brand-icon" style="background: linear-gradient(135deg, #ffd166, #ef476f);">🔑</div>
            <h1>Reset Password</h1>
            <p>Enter your email and we'll send a secure reset link</p>
        </div>
        
        <div class="glass-card p-4">
            <form method="post" action="{{ path('app_forgot_password') }}" id="forgot-form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('forgot_password') }}">
                
                <div class="mb-4">
                    <label class="form-label" for="forgot-email">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                        <input type="email" 
                               id="forgot-email"
                               name="email" 
                               class="form-control"
                               value="{{ email ?? '' }}"
                               placeholder="you@example.com"
                               autocomplete="email"
                               autofocus
                               required>
                    </div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-send me-2"></i>Send Reset Link
                </button>
            </form>
            
            <div class="text-center mt-4">
                <a href="{{ path('app_login') }}" class="text-muted small">
                    <i class="bi bi-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </div>
        
        <div class="text-center mt-3">
            <p class="text-muted" style="font-size: 0.75rem;">
                <i class="bi bi-shield-lock me-1"></i>
                For security, we never confirm whether an email exists in our system
            </p>
        </div>
    </div>
</div>
{% endblock %}
