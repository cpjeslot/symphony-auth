{% extends 'base.html.twig' %}

{% block title %}Reset Password{% endblock %}

{% block body %}
<div class="auth-container">
    <div class="auth-card animate-fade-in" style="max-width: 440px;">
        
        <div class="auth-brand">
            <div class="brand-icon" style="background: linear-gradient(135deg, #06d6a0, #4361ee);">🔒</div>
            <h1>Set New Password</h1>
            <p>Choose a strong password for your account</p>
        </div>
        
        <div class="glass-card p-4">
            <form method="post" action="{{ path('app_password_reset') }}" id="reset-form">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('reset_password') }}">
                <input type="hidden" name="token" value="{{ token }}">
                
                <div class="mb-3">
                    <label class="form-label" for="reset-password">New Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" 
                               id="reset-password"
                               name="password"
                               class="form-control"
                               placeholder="Min 8 chars, uppercase, number, special"
                               autocomplete="new-password"
                               autofocus
                               required>
                        <button class="btn btn-outline-secondary" type="button" id="toggleReset"
                                onclick="togglePassword('reset-password', 'toggleReset')">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <div class="password-strength mt-2" id="reset-strength"></div>
                </div>
                
                <div class="mb-4">
                    <label class="form-label" for="reset-confirm">Confirm New Password</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                        <input type="password" 
                               id="reset-confirm"
                               name="password_confirm"
                               class="form-control"
                               placeholder="Repeat your new password"
                               autocomplete="new-password"
                               required>
                    </div>
                    <div id="match-indicator" class="mt-1 small"></div>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-2" id="reset-submit" disabled>
                    <i class="bi bi-check-circle me-2"></i>Reset Password
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
const pwd = document.getElementById('reset-password');
const confirm = document.getElementById('reset-confirm');
const submit = document.getElementById('reset-submit');
const strengthBar = document.getElementById('reset-strength');
const matchEl = document.getElementById('match-indicator');

function checkForm() {
    const pwdVal = pwd.value;
    const confirmVal = confirm.value;
    const isStrong = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[^a-zA-Z\d]).{8,}$/.test(pwdVal);
    const matches = pwdVal === confirmVal && confirmVal.length > 0;
    
    // Strength bar
    const passed = [
        pwdVal.length >= 8,
        /[A-Z]/.test(pwdVal),
        /[a-z]/.test(pwdVal),
        /\d/.test(pwdVal),
        /[^a-zA-Z\d]/.test(pwdVal)
    ].filter(Boolean).length;
    
    const colors = ['', '#ef476f', '#ef476f', '#ffd166', '#ffd166', '#06d6a0'];
    strengthBar.style.background = colors[passed] || 'var(--border)';
    strengthBar.style.height = pwdVal.length > 0 ? '4px' : '0';
    
    // Match indicator
    if (confirmVal.length > 0) {
        matchEl.innerHTML = matches 
            ? '<span style="color:#06d6a0">✓ Passwords match</span>'
            : '<span style="color:#ef476f">✗ Passwords do not match</span>';
    }
    
    submit.disabled = !(isStrong && matches);
}

pwd.addEventListener('input', checkForm);
confirm.addEventListener('input', checkForm);
</script>
{% endblock %}
