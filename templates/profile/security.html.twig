{% extends 'base.html.twig' %}

{% block title %}Security Settings{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {# Sidebar #}
        <div class="col-md-3 col-lg-2 sidebar d-none d-md-block">
            <nav class="nav flex-column">
                <a href="{{ path('app_profile') }}" class="nav-link">
                    <i class="bi bi-person-circle"></i>Profile Overview
                </a>
                <a href="{{ path('app_profile_security') }}" class="nav-link active">
                    <i class="bi bi-shield-lock"></i>Security Settings
                </a>
                <a href="{{ path('app_profile_sessions') }}" class="nav-link">
                    <i class="bi bi-laptop"></i>Active Sessions
                </a>
                <a href="{{ path('app_profile_login_history') }}" class="nav-link">
                    <i class="bi bi-clock-history"></i>Login History
                </a>
                <hr style="border-color: var(--border);">
                <a href="{{ path('app_logout') }}" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>Sign Out
                </a>
            </nav>
        </div>

        {# Main Content #}
        <div class="col-md-9 col-lg-10 py-4 px-4">
            <div class="mb-4">
                <h2 class="fw-bold">Security Settings</h2>
                <p class="text-muted">Manage your account security and authentication methods.</p>
            </div>

            <div class="row g-4">
                {# Two-Factor Authentication #}
                <div class="col-md-12">
                    <div class="glass-card p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                        <div class="row g-3 mb-4">
                            {# Email Method #}
                            <div class="col-md-6">
                                <div class="p-3 rounded border {% if user.twoFactorType == 'email' %}border-primary bg-primary bg-opacity-10{% else %}border-secondary bg-dark{% endif %}">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 p-2 rounded">
                                            <i class="bi bi-envelope-at text-primary fs-5"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-medium small">Email OTP</div>
                                            <div class="text-muted smaller">{{ user.email }}</div>
                                        </div>
                                        {% if user.twoFactorEnabled and user.twoFactorType == 'email' %}
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>

                            {# TOTP Method #}
                            <div class="col-md-6">
                                <div class="p-3 rounded border {% if user.twoFactorType == 'totp' %}border-primary bg-primary bg-opacity-10{% else %}border-secondary bg-dark{% endif %}">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-info bg-opacity-10 p-2 rounded">
                                            <i class="bi bi-phone text-info fs-5"></i>
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="fw-medium small">Authenticator App</div>
                                            <div class="text-muted smaller">Google Auth, Authy...</div>
                                        </div>
                                        {% if user.twoFactorEnabled and user.twoFactorType == 'totp' %}
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-3">
                            {% if user.twoFactorEnabled %}
                                <form action="{{ path('app_2fa_disable') }}" method="POST">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa_disable') }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-shield-x me-2"></i>Disable 2FA
                                    </button>
                                </form>
                                {% if user.twoFactorType == 'email' %}
                                    <a href="{{ path('app_2fa_setup_totp') }}" class="btn btn-outline-info btn-sm">
                                        <i class="bi bi-phone me-2"></i>Switch to App
                                    </a>
                                {% endif %}
                            {% else %}
                                <form action="{{ path('app_2fa_enable') }}" method="POST" class="d-inline">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa_enable') }}">
                                    <button type="submit" class="btn btn-primary btn-sm">
                                        <i class="bi bi-envelope me-2"></i>Enable Email OTP
                                    </button>
                                </form>
                                <a href="{{ path('app_2fa_setup_totp') }}" class="btn btn-outline-info btn-sm">
                                    <i class="bi bi-phone me-2"></i>Setup Authenticator
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>

                {# Password Management #}
                <div class="col-md-6">
                    <div class="glass-card p-4 h-100">
                        <h5 class="fw-bold mb-3">Password</h5>
                        <p class="text-muted small mb-4">It's a good idea to use a strong password that you're not using elsewhere.</p>
                        
                        <div class="d-flex align-items-center justify-content-between p-3 rounded border border-secondary mb-4">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-key text-muted"></i>
                                <span class="small">Last changed: {{ user.lastLogin ? user.lastLogin|date('M j, Y') : 'Never' }}</span>
                            </div>
                            <a href="{{ path('app_profile_change_password') }}" class="btn btn-sm btn-outline-primary">Change</a>
                        </div>
                    </div>
                </div>

                {# Identity Verification #}
                <div class="col-md-6">
                    <div class="glass-card p-4 h-100">
                        <h5 class="fw-bold mb-3">Identity Verification</h5>
                        <p class="text-muted small mb-4">Verify your information to ensure account recovery options.</p>
                        
                        <ul class="list-unstyled mb-0">
                            <li class="d-flex justify-content-between align-items-center mb-3">
                                <div>
                                    <div class="small fw-medium">Email Address</div>
                                    <div class="text-muted smaller">{{ user.email }}</div>
                                </div>
                                {% if user.emailVerified %}
                                    <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Verified</span>
                                {% else %}
                                    <span class="text-warning small"><i class="bi bi-exclamation-triangle-fill me-1"></i>Pending</span>
                                {% endif %}
                            </li>
                            <li class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="small fw-medium">Mobile Number</div>
                                    <div class="text-muted smaller">{{ user.mobileNumber ?? 'Not provided' }}</div>
                                </div>
                                {% if user.mobileNumber %}
                                    <span class="text-success small"><i class="bi bi-check-circle-fill me-1"></i>Linked</span>
                                {% else %}
                                    <button class="btn btn-sm btn-link text-primary p-0">Add</button>
                                {% endif %}
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
