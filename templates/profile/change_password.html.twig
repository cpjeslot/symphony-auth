{% extends 'base.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block body %}
<div class="container-fluid">
    <div class="row">
        {# Sidebar #}
        <div class="col-md-3 col-lg-2 sidebar d-none d-md-block">
            <nav class="nav flex-column">
                <a href="{{ path('app_profile') }}" class="nav-link">
                    <i class="bi bi-person-circle"></i>Profile Overview
                </a>
                <a href="{{ path('app_profile_security') }}" class="nav-link active">
                    <i class="bi bi-shield-lock"></i>Security Settings
                </a>
                <a href="{{ path('app_profile_sessions') }}" class="nav-link">
                    <i class="bi bi-laptop"></i>Active Sessions
                </a>
                <a href="{{ path('app_profile_login_history') }}" class="nav-link">
                    <i class="bi bi-clock-history"></i>Login History
                </a>
                <hr style="border-color: var(--border);">
                <a href="{{ path('app_logout') }}" class="nav-link text-danger">
                    <i class="bi bi-box-arrow-right"></i>Sign Out
                </a>
            </nav>
        </div>

        {# Main Content #}
        <div class="col-md-9 col-lg-10 py-4 px-4">
            <div class="mb-4">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="{{ path('app_profile_security') }}">Security</a></li>
                        <li class="breadcrumb-item active">Change Password</li>
                    </ol>
                </nav>
                <h2 class="fw-bold">Change Password</h2>
                <p class="text-muted">Ensure your account is using a long, random password to stay secure.</p>
            </div>

            <div class="row">
                <div class="col-lg-6">
                    <div class="glass-card p-4">
                        <form method="POST" action="{{ path('app_profile_change_password') }}">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('change_password') }}">
                            
                            <div class="mb-3">
                                <label class="form-label" for="current_password">Current Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-shield-lock"></i></span>
                                    <input type="password" id="current_password" name="current_password" class="form-control" required>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label" for="new_password">New Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-key"></i></span>
                                    <input type="password" id="new_password" name="new_password" class="form-control" required>
                                    <button class="btn btn-outline-secondary" type="button" id="toggleNewPwd" onclick="togglePassword('new_password', 'toggleNewPwd')">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                                <div class="password-strength mt-2" id="strength-bar" style="height: 4px; background: var(--border); border-radius: 2px;"></div>
                                <small class="text-muted mt-2 d-block" style="font-size: 0.75rem;">
                                    Must be at least 8 characters with uppercase, lowercase, number, and special character.
                                </small>
                            </div>

                            <div class="mb-4">
                                <label class="form-label" for="confirm_password">Confirm New Password</label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-check-circle"></i></span>
                                    <input type="password" id="confirm_password" name="confirm_password" class="form-control" required>
                                </div>
                            </div>

                            <div class="d-flex justify-content-end gap-3">
                                <a href="{{ path('app_profile_security') }}" class="btn btn-outline-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary px-4">Update Password</button>
                            </div>
                        </form>
                    </div>
                </div>
                
                <div class="col-lg-4">
                    <div class="card bg-info bg-opacity-10 border-info border-opacity-20 p-4">
                        <h6 class="text-info fw-bold mb-3"><i class="bi bi-lightbulb me-2"></i>Password Tips</h6>
                        <ul class="small text-info text-opacity-75 mb-0 ps-3">
                            <li class="mb-2">Use a combination of at least 12 characters</li>
                            <li class="mb-2">Avoid using names, birthdays, or common words</li>
                            <li class="mb-2">Use a password manager to generate and store unique passwords</li>
                            <li>Enable 2FA for maximum protection</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
const newPwd = document.getElementById('new_password');
const bar = document.getElementById('strength-bar');

newPwd.addEventListener('input', function() {
    const val = this.value;
    const checks = [
        val.length >= 8,
        /[A-Z]/.test(val),
        /[a-z]/.test(val),
        /\d/.test(val),
        /[^a-zA-Z\d]/.test(val)
    ].filter(Boolean).length;
    
    const colors = ['#ef476f', '#ef476f', '#ffd166', '#ffd166', '#06d6a0', '#06d6a0'];
    const widths = ['0%', '20%', '40%', '60%', '80%', '100%'];
    
    bar.style.width = widths[checks];
    bar.style.backgroundColor = colors[checks];
});
</script>
{% endblock %}
