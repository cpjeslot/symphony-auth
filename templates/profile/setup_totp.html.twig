{% extends 'base.html.twig' %}

{% block title %}Setup Authenticator App{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="auth-brand mb-4 text-center">
                <div class="brand-icon" style="background: linear-gradient(135deg, #4361ee, #4cc9f0);">📱</div>
                <h2 class="fw-bold mt-3">Authenticator App</h2>
                <p class="text-muted">Enhance your security with TOTP verification</p>
            </div>

            <div class="glass-card p-4 animate-fade-in">
                <div class="mb-4">
                    <h5 class="fw-bold mb-3">1. Scan QR Code</h5>
                    <p class="small text-muted">Scan this image with your authenticator app (e.g., Google Authenticator, Authy, or Microsoft Authenticator).</p>
                    
                    <div class="d-flex justify-content-center bg-white p-3 rounded mb-3 shadow-sm" style="min-height: 200px;">
                        <div id="qrcode"></div>
                    </div>
                    
                    <div class="text-center">
                        <button class="btn btn-link btn-sm text-primary p-0" type="button" data-bs-toggle="collapse" data-bs-target="#manualEntry">
                            Can't scan? Use manual entry
                        </button>
                        <div class="collapse mt-2" id="manualEntry">
                            <div class="p-2 bg-dark rounded border border-secondary">
                                <code class="text-info fw-bold" style="letter-spacing: 2px;">{{ secret }}</code>
                            </div>
                            <small class="text-muted d-block mt-1">Account: {{ user.email }}</small>
                        </div>
                    </div>
                </div>

                <hr class="border-secondary opacity-25">

                <div class="mt-4">
                    <h5 class="fw-bold mb-3">2. Verify Code</h5>
                    <p class="small text-muted">Enter the 6-digit code generated by your app to finalize setup.</p>
                    
                    <form action="{{ path('app_2fa_enable_totp') }}" method="POST">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('totp_enable') }}">
                        
                        <div class="mb-3">
                            <input type="text" 
                                   name="code" 
                                   class="form-control text-center fw-bold fs-4" 
                                   placeholder="000000" 
                                   maxlength="6" 
                                   pattern="\d{6}" 
                                   required 
                                   autofocus>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary py-2">
                                <i class="bi bi-shield-check me-2"></i>Enable Authenticator
                            </button>
                            <a href="{{ path('app_profile_security') }}" class="btn btn-outline-secondary">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const qrUri = "{{ qr_uri|raw }}";
        new QRCode(document.getElementById("qrcode"), {
            text: qrUri,
            width: 200,
            height: 200,
            colorDark : "#000000",
            colorLight : "#ffffff",
            correctLevel : QRCode.CorrectLevel.H
        });
    });
</script>
{% endblock %}
