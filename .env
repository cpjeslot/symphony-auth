###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=dev-secret-change-me-in-production
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR
TRUSTED_HOSTS='^(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< symfony/framework-bundle ###

###> Database ###
DATABASE_URL="postgresql://postgres:12345678@127.0.0.1:5432/auth_db?serverVersion=16&charset=utf8"
###< Database ###

###> Mailer ###
MAILER_DSN=smtp://localhost:1025
MAILER_FROM_ADDRESS=noreply@localhost
MAILER_FROM_NAME="Auth System Dev"
###< Mailer ###

###> Redis ###
REDIS_URL=redis://127.0.0.1:6379
###< Redis ###

###> JWT ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=78314069d586df545eada5353a53496948a4d6e59aac02f31e6ab70a0e9d8782
JWT_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=2592000
###< JWT ###

###> OAuth2 ###
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY_PATH=%kernel.project_dir%/config/oauth/apple_private_key.p8
###< OAuth2 ###

###> Application Settings ###
APP_DOMAIN=http://localhost:8000
OTP_EXPIRY_SECONDS=300
OTP_RESEND_COOLDOWN=60
OTP_MAX_RETRIES=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=30
PASSWORD_RESET_EXPIRY_HOURS=2
EMAIL_VERIFY_EXPIRY_HOURS=48
SESSION_LIFETIME=7200
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< Application Settings ###

###> symfony/routing ###
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=redis://127.0.0.1:6379/messages
###< symfony/messenger ###
