###> symfony/framework-bundle ###
APP_ENV=production
APP_SECRET=change-me-to-a-secure-random-32-char-string
###< symfony/framework-bundle ###

###> Database - PostgreSQL ###
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?serverVersion=16&charset=utf8
DATABASE_URL="postgresql://auth_user:strong_password_here@127.0.0.1:5432/auth_db?serverVersion=16&charset=utf8"
###< Database - PostgreSQL ###

###> Mailer ###
# SMTP example: smtp://user:password@smtp.example.com:587?encryption=tls
MAILER_DSN=smtp://user:password@smtp.mailtrap.io:2525
MAILER_FROM_ADDRESS=noreply@yourdomain.com
MAILER_FROM_NAME="Auth System"
###< Mailer ###

###> Redis (optional) ###
# Comment out to disable Redis; system falls back to filesystem
REDIS_URL=redis://127.0.0.1:6379
###< Redis ###

###> JWT Authentication ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change-me-to-a-strong-passphrase
JWT_TOKEN_TTL=3600
JWT_REFRESH_TOKEN_TTL=2592000
###< JWT Authentication ###

###> OAuth2 - Google ###
OAUTH_GOOGLE_CLIENT_ID=your-google-client-id
OAUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret
###< OAuth2 - Google ###

###> OAuth2 - GitHub ###
OAUTH_GITHUB_CLIENT_ID=your-github-client-id
OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret
###< OAuth2 - GitHub ###

###> OAuth2 - Facebook ###
OAUTH_FACEBOOK_CLIENT_ID=your-facebook-app-id
OAUTH_FACEBOOK_CLIENT_SECRET=your-facebook-app-secret
###< OAuth2 - Facebook ###

###> OAuth2 - Apple ###
OAUTH_APPLE_CLIENT_ID=your.apple.service.id
OAUTH_APPLE_TEAM_ID=YOUR_TEAM_ID
OAUTH_APPLE_KEY_ID=YOUR_KEY_ID
OAUTH_APPLE_PRIVATE_KEY_PATH=%kernel.project_dir%/config/oauth/apple_private_key.p8
###< OAuth2 - Apple ###

###> Application Settings ###
APP_DOMAIN=https://yourdomain.com
# OTP validity in seconds (default: 300 = 5 minutes)
OTP_EXPIRY_SECONDS=300
# OTP resend cooldown in seconds (default: 60)
OTP_RESEND_COOLDOWN=60
# Max OTP retry attempts before lockout
OTP_MAX_RETRIES=5
# Max failed login attempts before temporary lock
LOGIN_MAX_ATTEMPTS=5
# Account lock duration in minutes
LOGIN_LOCK_MINUTES=30
# Password reset token expiry in hours
PASSWORD_RESET_EXPIRY_HOURS=2
# Email verification token expiry in hours
EMAIL_VERIFY_EXPIRY_HOURS=48
# Session lifetime in seconds
SESSION_LIFETIME=7200
###< Application Settings ###

###> Security ###
# CORS allowed origins (comma-separated for API)
CORS_ALLOW_ORIGIN='^https?://(localhost|yourdomain\.com)(:[0-9]+)?$'
###< Security ###
